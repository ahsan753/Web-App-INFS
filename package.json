{
  "name": "infs1101-python-trainer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run prepare:teacher && npm run validate:content",
    "build": "next build --webpack",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "validate:content": "node --import tsx scripts/validate-content.ts",
    "prepare:teacher": "node scripts/prepare-teacher-route.mjs",
    "postinstall": "node scripts/copy-pyodide.mjs"
  },
  "dependencies": {
    "@tailwindcss/postcss": "4.3.1",
    "lucide-react": "1.18.0",
    "next": "16.2.9",
    "prismjs": "^1.30.0",
    "pyodide": "0.28.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-simple-code-editor": "^0.14.1",
    "tailwindcss": "4.3.1"
  },
  "devDependencies": {
    "@types/node": "24.10.2",
    "@types/prismjs": "^1.26.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}
